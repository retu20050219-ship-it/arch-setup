{
	"custom/spacer": {
		"format": " ",
		"tooltip": false
	},
	"custom/rightend": {
		"format": "  ",
		"tooltip": false
	},
	"custom/leftend": {
		"format": "  ",
		"tooltip": false
	},
	"custom/emptyspacer": {
		"format": "  ",
